# Kolya — .htaccess
# Hostinger / Apache shared hosting

# ============================================================
# Force HTTPS + www
# Anything that arrives on http://kolya.fr, http://www.kolya.fr,
# or https://kolya.fr is redirected to https://www.kolya.fr
# with the original path/query preserved.
# ============================================================
<IfModule mod_rewrite.c>
  RewriteEngine On

  RewriteCond %{HTTPS} off [OR]
  RewriteCond %{HTTP_HOST} !^www\. [NC]
  RewriteCond %{HTTP_HOST} ^(?:www\.)?(.+)$ [NC]
  RewriteRule ^ https://www.%1%{REQUEST_URI} [L,R=301]
</IfModule>

# ============================================================
# Default index
# ============================================================
DirectoryIndex index.html

# ============================================================
# Pretty URLs:
#   - hide /index.html in URLs
#   - force trailing slash on directories (/metiers/marches → /metiers/marches/)
# ============================================================
<IfModule mod_rewrite.c>
  RewriteEngine On

  # /metiers/marches/index.html → /metiers/marches/
  RewriteCond %{THE_REQUEST} \s/+(.*?)/?index\.html[\s?] [NC]
  RewriteRule ^ /%1/ [L,R=301]

  # /metiers/marches → /metiers/marches/
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteCond %{REQUEST_URI} !/$
  RewriteRule ^ %{REQUEST_URI}/ [L,R=301]
</IfModule>

# ============================================================
# Long-cache static assets, short-cache HTML
# ============================================================
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType image/jpeg     "access plus 1 year"
  ExpiresByType image/png      "access plus 1 year"
  ExpiresByType image/webp     "access plus 1 year"
  ExpiresByType image/svg+xml  "access plus 1 year"
  ExpiresByType image/x-icon   "access plus 1 year"
  ExpiresByType font/woff2     "access plus 1 year"
  ExpiresByType font/woff      "access plus 1 year"
  ExpiresByType text/css       "access plus 1 year"
  ExpiresByType application/javascript "access plus 1 year"
  ExpiresByType application/xml "access plus 1 day"
  # HTML never long-cached so deploys propagate immediately. CSS/JS use
  # ?v=N versioning in the HTML link, so they can stay long-cached safely.
  ExpiresByType text/html      "access plus 0 seconds"
</IfModule>

<IfModule mod_headers.c>
  # Force HTML to revalidate every load. Browser sends If-Modified-Since;
  # server replies 304 Not Modified when content hasn't changed → no transfer.
  <FilesMatch "\.html$">
    Header set Cache-Control "no-cache, must-revalidate, max-age=0"
  </FilesMatch>
</IfModule>

# ============================================================
# Compression for text-based assets
# ============================================================
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json image/svg+xml application/xml
</IfModule>

# ============================================================
# Security headers
# ============================================================
<IfModule mod_headers.c>
  Header set X-Content-Type-Options "nosniff"
  Header set X-Frame-Options "SAMEORIGIN"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
  Header set Permissions-Policy "camera=(), microphone=(), geolocation=()"
</IfModule>

# ============================================================
# Block access to internal files (design docs, hidden config)
# ============================================================
<FilesMatch "(^\.|^PRODUCT\.md$|^DESIGN\.md$|^DESIGN\.json$|^README\.md$|\.log$)">
  Require all denied
</FilesMatch>
